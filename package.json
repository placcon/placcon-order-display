{
  "name": "placcon-launcher",
  "version": "1.11.1",
  "description": "Placcon Restaurant System Desktop Launcher",
  "main": "main.js",
  "scripts": {
    "start": "electron . --expose-gc",
    "dev": "electron . --dev --expose-gc",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder -mwl",
    "dist": "npm run build:all",
    "release": "scripts/create-release.sh",
    "check-version": "scripts/check-version.sh",
    "check-release": "scripts/check-release.sh"
  },
  "keywords": [
    "electron",
    "placcon",
    "restaurant",
    "launcher"
  ],
  "author": "Placcon <info@placcon.com>",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.placcon.launcher",
    "productName": "Placcon Launcher",
    "electronVersion": "28.0.0",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload-simple.js",
      "renderer.js",
      "index.html",
      "assets/**/*"
    ],
    "publish": null,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.business",
      "identity": null
    },
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/"
      }
    ],
    "protocols": [
      {
        "name": "Placcon Launcher",
        "schemes": ["placcon"]
      }
    ]
  },
  "dependencies": {
    "@serialport/list": "^13.0.0",
    "path": "^0.12.7",
    "serialport": "^13.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=8.0.0"
  }
}
