{
  "name": "placcon-order-display-win32",
  "version": "2.5.5-order",
  "description": "Placcon Order Display System - Windows 32-bit",
  "main": "main.js",
  "scripts": {
    "build": "electron-builder --win --ia32"
  },
  "author": "Placcon <info@placcon.com>",
  "license": "MIT",
  "devDependencies": {
    "electron": "22.3.27",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.placcon.order-display",
    "productName": "placcon order display",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "assets/**/*"
    ],
    "publish": null,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "ia32"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "perMachine": false,
      "allowElevation": false
    }
  }
}
